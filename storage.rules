rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userRole() {
      return signedIn()
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return userRole() in ['admin', 'manager'];
    }

    function safeFile() {
      return request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType in [
          'image/jpeg',
          'image/png',
          'image/webp',
          'image/gif',
          'application/pdf',
          'text/csv',
          'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
        ];
    }

    match /candidates/{candidateId}/{folder}/{fileName} {
      allow read: if signedIn() && (request.auth.uid == candidateId || isAdmin());
      allow write: if signedIn() && (request.auth.uid == candidateId || isAdmin()) && safeFile();
      allow delete: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
